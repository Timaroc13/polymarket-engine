# Copy to .env (do not commit .env)
# Local dev / Cloud Run env vars

# Optional: require Authorization: Bearer <API_KEY>
API_KEY=

# Optional: stamped into responses for traceability
MODEL_VERSION=news-parser-0.1

# Optional: enable persistence (SQLite) + feedback endpoint
ENABLE_PERSISTENCE=0

# Optional: override DB path
# DB_PATH=C:\dev\crypto-news-parser\data.sqlite3

# Optional: LLM p_model estimation for POST /signal
LLM_ENABLE=0
LLM_PROVIDER=gemini
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: in-process scheduler (flow scans + resolution polls + Telegram alerts)
SCHEDULER_ENABLE=0
# SCAN_INTERVAL_HOURS=4
# POLL_INTERVAL_MINUTES=15
# SCAN_TOP_N=20
# SCAN_MAX_WALLETS=300
# SCAN_CATEGORIES=crypto      # comma-separated allow-list; crypto is the only category with edge so far
# SCAN_MAX_DAYS=30            # crypto markets resolve slower than the old 7-day sports default
# ALERT_MIN_TIER=HIGH
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
